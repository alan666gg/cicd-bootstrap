name: __WORKFLOW_NAME__

on:
  pull_request:
  push:
    branches:
__CI_BRANCH_LINES__

permissions:
  contents: read

concurrency:
  group: __CONCURRENCY_GROUP__
  cancel-in-progress: true

jobs:
  test-and-build:
    runs-on: __RUNNER__
    timeout-minutes: __JOB_TIMEOUT_MINUTES__
    defaults:
      run:
        shell: "__DEFAULT_SHELL__"
        working-directory: __SERVICE_PATH__
    steps:
      - name: Checkout
        uses: __ACTION_CHECKOUT__

      - name: Setup Node
        uses: __ACTION_SETUP_NODE__
        with:
          node-version: 20
__NODE_CACHE_BLOCK__

      - name: Install dependencies
        run: __INSTALL_COMMAND__

      - name: Run tests
        run: __TEST_COMMAND__

      - name: Build
        run: __BUILD_COMMAND__

      - name: Validate Docker build
        if: ${{ hashFiles('__DOCKER_CONTEXT__/Dockerfile') != '' }}
        run: docker build -t __APP_NAME__:ci __DOCKER_CONTEXT__
__SECURITY_SCAN_JOB__
