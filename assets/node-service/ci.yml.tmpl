name: CI

on:
  pull_request:
  push:
    branches:
      - main
      - __TEST_BRANCH__

jobs:
  test-and-build:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: __SERVICE_PATH__
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Run tests
        run: npm test --if-present

      - name: Build
        run: npm run build --if-present

      - name: Validate Docker build
        if: ${{ hashFiles('__DOCKER_CONTEXT__/Dockerfile') != '' }}
        run: docker build -t __APP_NAME__:ci __DOCKER_CONTEXT__
