name: __WORKFLOW_NAME__

on:
  workflow_dispatch:
  push:
    branches:
__TEST_BRANCH_LINES__

permissions:
  contents: read
  packages: write

concurrency:
  group: __CONCURRENCY_GROUP__
  cancel-in-progress: true

jobs:
  publish-test-image:
    runs-on: __RUNNER__
    timeout-minutes: 30
    environment: __TEST_ENVIRONMENT__
    env:
      APP_NAME: __APP_NAME__
      CONFIGURED_IMAGE_REGISTRY: __IMAGE_REGISTRY__
      OVERRIDE_IMAGE_REGISTRY: ${{ vars.IMAGE_REGISTRY }}
      IMAGE_TAG: test-${{ github.sha }}
      IMAGE_BRANCH_TAG: test-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Resolve image target
        id: image
        shell: bash
        run: |
          registry="${OVERRIDE_IMAGE_REGISTRY:-$CONFIGURED_IMAGE_REGISTRY}"
          registry="${registry,,}"
          registry="${registry%/}"
          if [[ -z "$registry" ]]; then
            echo "::error::image registry is empty"
            exit 1
          fi
          echo "image_name=${registry}/${APP_NAME}" >> "$GITHUB_OUTPUT"
          echo "registry_host=${registry%%/*}" >> "$GITHUB_OUTPUT"

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Login to registry
        uses: docker/login-action@v3
        with:
          registry: ${{ steps.image.outputs.registry_host }}
          username: ${{ secrets.REGISTRY_USERNAME }}
          password: ${{ secrets.REGISTRY_PASSWORD }}

      - name: Build and push test image
        uses: docker/build-push-action@v6
        with:
          context: __DOCKER_CONTEXT__
          push: true
          tags: |
            ${{ steps.image.outputs.image_name }}:${{ env.IMAGE_TAG }}
            ${{ steps.image.outputs.image_name }}:${{ env.IMAGE_BRANCH_TAG }}
