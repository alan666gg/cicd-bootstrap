name: __WORKFLOW_NAME__

on:
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: __CONCURRENCY_GROUP__
  cancel-in-progress: true

jobs:
  deploy-prod:
    runs-on: __RUNNER__
    timeout-minutes: __DEPLOY_TIMEOUT_MINUTES__
    environment: __PROD_ENVIRONMENT__
    defaults:
      run:
        shell: "__DEFAULT_SHELL__"
    env:
      APP_NAME: __APP_NAME__
      IMAGE_TAG: __APP_NAME__:${{ github.sha }}
      PROD_HOST: ${{ vars.PROD_HOST }}
      PROD_USER: ${{ vars.PROD_USER }}
      PROD_PORT: ${{ vars.PROD_PORT || '22' }}
      PROD_REMOTE_DIR: ${{ vars.PROD_REMOTE_DIR }}
      PROD_CONTAINER_NAME: ${{ vars.PROD_CONTAINER_NAME }}
      PROD_DOCKER_RUN_ARGS: ${{ vars.PROD_DOCKER_RUN_ARGS }}
      PROD_HEALTHCHECK_URL: ${{ vars.PROD_HEALTHCHECK_URL || '__PROD_HEALTHCHECK_URL__' }}
      PROD_HEALTHCHECK_TIMEOUT_SECONDS: ${{ vars.PROD_HEALTHCHECK_TIMEOUT_SECONDS || '__HEALTHCHECK_TIMEOUT_SECONDS__' }}
      PROD_ROLLBACK_ON_FAILURE: ${{ vars.PROD_ROLLBACK_ON_FAILURE || '__ROLLBACK_ON_FAILURE__' }}
      PROD_REMOTE_IMAGE_RETENTION: ${{ vars.PROD_REMOTE_IMAGE_RETENTION || '__REMOTE_IMAGE_RETENTION__' }}
    steps:
      - name: Checkout
        uses: __ACTION_CHECKOUT__

      - name: Build image
        run: docker build -t "$IMAGE_TAG" __DOCKER_CONTEXT__

      - name: Save image tarball
        run: docker save "$IMAGE_TAG" -o "${APP_NAME}_${{ github.sha }}.tar"

      - name: Setup SSH key
        uses: __ACTION_SSH_AGENT__
        with:
          ssh-private-key: ${{ secrets.PROD_SSH_KEY }}

      - name: Add prod host to known_hosts
        run: ssh-keyscan -p "$PROD_PORT" -H "$PROD_HOST" >> ~/.ssh/known_hosts

      - name: Create remote dir
        run: ssh -p "$PROD_PORT" "${PROD_USER}@${PROD_HOST}" "mkdir -p '${PROD_REMOTE_DIR}'"

      - name: Upload image
        run: scp -P "$PROD_PORT" "${APP_NAME}_${{ github.sha }}.tar" "${PROD_USER}@${PROD_HOST}:${PROD_REMOTE_DIR}/"

      - name: Upload remote deploy script
        run: scp -P "$PROD_PORT" "__REMOTE_DEPLOY_SCRIPT_PATH__" "${PROD_USER}@${PROD_HOST}:${PROD_REMOTE_DIR}/remote_deploy.sh"

      - name: Switch container
        run: |
          ssh -p "$PROD_PORT" "${PROD_USER}@${PROD_HOST}" \
            "IMAGE_TAG='${IMAGE_TAG}' REMOTE_DIR='${PROD_REMOTE_DIR}' TARBALL_NAME='${APP_NAME}_${{ github.sha }}.tar' CONTAINER_NAME='${PROD_CONTAINER_NAME}' DOCKER_RUN_ARGS='${PROD_DOCKER_RUN_ARGS}' HEALTHCHECK_URL='${PROD_HEALTHCHECK_URL}' HEALTHCHECK_TIMEOUT_SECONDS='${PROD_HEALTHCHECK_TIMEOUT_SECONDS}' ROLLBACK_ON_FAILURE='${PROD_ROLLBACK_ON_FAILURE}' REMOTE_IMAGE_RETENTION='${PROD_REMOTE_IMAGE_RETENTION}' bash '${PROD_REMOTE_DIR}/remote_deploy.sh'"
