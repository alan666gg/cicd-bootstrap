name: __WORKFLOW_NAME__

on:
  workflow_dispatch:

permissions:
  contents: read
  packages: write

concurrency:
  group: __CONCURRENCY_GROUP__
  cancel-in-progress: true

jobs:
  publish-prod-image:
    runs-on: __RUNNER__
    timeout-minutes: __DEPLOY_TIMEOUT_MINUTES__
    environment: __PROD_ENVIRONMENT__
    defaults:
      run:
        shell: "__DEFAULT_SHELL__"
    env:
      APP_NAME: __APP_NAME__
      CONFIGURED_IMAGE_REGISTRY: __IMAGE_REGISTRY__
      OVERRIDE_IMAGE_REGISTRY: ${{ vars.IMAGE_REGISTRY }}
      IMAGE_TAG: prod-${{ github.sha }}
      IMAGE_LATEST_TAG: latest
    steps:
      - name: Checkout
        uses: __ACTION_CHECKOUT__

      - name: Resolve image target
        id: image
        shell: bash
        run: |
          registry="${OVERRIDE_IMAGE_REGISTRY:-$CONFIGURED_IMAGE_REGISTRY}"
          registry="${registry,,}"
          registry="${registry%/}"
          if [[ -z "$registry" ]]; then
            echo "::error::image registry is empty"
            exit 1
          fi
          echo "image_name=${registry}/${APP_NAME}" >> "$GITHUB_OUTPUT"
          echo "registry_host=${registry%%/*}" >> "$GITHUB_OUTPUT"

      - name: Set up Docker Buildx
        uses: __ACTION_SETUP_BUILDX__

      - name: Login to registry
        uses: __ACTION_DOCKER_LOGIN__
        with:
          registry: ${{ steps.image.outputs.registry_host }}
          username: ${{ secrets.REGISTRY_USERNAME }}
          password: ${{ secrets.REGISTRY_PASSWORD }}

__DEPENDENCY_REMINDER_STEP__
      - name: Build and push production image
        uses: __ACTION_DOCKER_BUILD_PUSH__
        with:
          context: __DOCKER_CONTEXT__
          push: true
          tags: |
            ${{ steps.image.outputs.image_name }}:${{ env.IMAGE_TAG }}
            ${{ steps.image.outputs.image_name }}:${{ env.IMAGE_LATEST_TAG }}
