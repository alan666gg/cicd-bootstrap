name: __WORKFLOW_NAME__

on:
  workflow_dispatch:
  push:
    branches:
__TEST_BRANCH_LINES__

permissions:
  contents: read

concurrency:
  group: __CONCURRENCY_GROUP__
  cancel-in-progress: true

jobs:
  deploy-test:
    runs-on: __RUNNER__
    timeout-minutes: __DEPLOY_TIMEOUT_MINUTES__
    environment: __TEST_ENVIRONMENT__
    defaults:
      run:
        shell: "__DEFAULT_SHELL__"
    env:
      APP_NAME: __APP_NAME__
      IMAGE_TAG: __APP_NAME__:${{ github.sha }}
      TEST_HOST: ${{ vars.TEST_HOST }}
      TEST_USER: ${{ vars.TEST_USER }}
      TEST_PORT: ${{ vars.TEST_PORT || '22' }}
      TEST_REMOTE_DIR: ${{ vars.TEST_REMOTE_DIR }}
      TEST_CONTAINER_NAME: ${{ vars.TEST_CONTAINER_NAME }}
      TEST_DOCKER_RUN_ARGS: ${{ vars.TEST_DOCKER_RUN_ARGS }}
      TEST_HEALTHCHECK_URL: ${{ vars.TEST_HEALTHCHECK_URL || '__TEST_HEALTHCHECK_URL__' }}
      TEST_HEALTHCHECK_TIMEOUT_SECONDS: ${{ vars.TEST_HEALTHCHECK_TIMEOUT_SECONDS || '__HEALTHCHECK_TIMEOUT_SECONDS__' }}
      TEST_ROLLBACK_ON_FAILURE: ${{ vars.TEST_ROLLBACK_ON_FAILURE || '__ROLLBACK_ON_FAILURE__' }}
      TEST_REMOTE_IMAGE_RETENTION: ${{ vars.TEST_REMOTE_IMAGE_RETENTION || '__REMOTE_IMAGE_RETENTION__' }}
    steps:
      - name: Checkout
        uses: __ACTION_CHECKOUT__

      - name: Build image
        run: docker build -t "$IMAGE_TAG" __DOCKER_CONTEXT__

      - name: Save image tarball
        run: docker save "$IMAGE_TAG" -o "${APP_NAME}_${{ github.sha }}.tar"

      - name: Setup SSH key
        uses: __ACTION_SSH_AGENT__
        with:
          ssh-private-key: ${{ secrets.TEST_SSH_KEY }}

      - name: Add test host to known_hosts
        run: ssh-keyscan -p "$TEST_PORT" -H "$TEST_HOST" >> ~/.ssh/known_hosts

      - name: Create remote dir
        run: ssh -p "$TEST_PORT" "${TEST_USER}@${TEST_HOST}" "mkdir -p '${TEST_REMOTE_DIR}'"

      - name: Upload image
        run: scp -P "$TEST_PORT" "${APP_NAME}_${{ github.sha }}.tar" "${TEST_USER}@${TEST_HOST}:${TEST_REMOTE_DIR}/"

      - name: Upload remote deploy script
        run: scp -P "$TEST_PORT" "__REMOTE_DEPLOY_SCRIPT_PATH__" "${TEST_USER}@${TEST_HOST}:${TEST_REMOTE_DIR}/remote_deploy.sh"

__DEPENDENCY_UPLOAD_STEP__
__DEPENDENCY_CHECK_STEP__
      - name: Switch container
        run: |
          ssh -p "$TEST_PORT" "${TEST_USER}@${TEST_HOST}" \
            "IMAGE_TAG='${IMAGE_TAG}' REMOTE_DIR='${TEST_REMOTE_DIR}' TARBALL_NAME='${APP_NAME}_${{ github.sha }}.tar' CONTAINER_NAME='${TEST_CONTAINER_NAME}' DOCKER_RUN_ARGS='${TEST_DOCKER_RUN_ARGS}' HEALTHCHECK_URL='${TEST_HEALTHCHECK_URL}' HEALTHCHECK_TIMEOUT_SECONDS='${TEST_HEALTHCHECK_TIMEOUT_SECONDS}' ROLLBACK_ON_FAILURE='${TEST_ROLLBACK_ON_FAILURE}' REMOTE_IMAGE_RETENTION='${TEST_REMOTE_IMAGE_RETENTION}' bash '${TEST_REMOTE_DIR}/remote_deploy.sh'"
