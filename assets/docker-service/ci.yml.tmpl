name: __WORKFLOW_NAME__

on:
  pull_request:
  push:
    branches:
__CI_BRANCH_LINES__

permissions:
  contents: read

concurrency:
  group: __CONCURRENCY_GROUP__
  cancel-in-progress: true

jobs:
  docker-build:
    runs-on: __RUNNER__
    timeout-minutes: 20
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Validate Docker build
        run: docker build -t __APP_NAME__:ci __DOCKER_CONTEXT__
__SECURITY_SCAN_JOB__
