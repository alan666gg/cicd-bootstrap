name: CI

on:
  pull_request:
  push:
    branches:
      - main
      - __TEST_BRANCH__

jobs:
  docker-build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Validate Docker build
        run: docker build -t __APP_NAME__:ci __DOCKER_CONTEXT__
